{
  "project": "recanto",
  "description": "Mapa resumido do repositório para navegação por IA e humanos.",
  "stack": ["Next.js 15", "React 19", "TypeScript", "Tailwind", "Drizzle ORM", "Neon Postgres", "shadcn/ui"],
  "entryPoints": {
    "app": "app/layout.tsx, app/page.tsx",
    "database": "lib/db/schema.ts, lib/db/index.ts, drizzle.config.ts",
    "categoryHelpers": "lib/category-helpers.ts"
  },
  "directories": {
    "app": "Rotas e layouts (App Router)",
    "components": "UI de feature + primitivos em components/ui/",
    "lib": "DB, parsers, importação, utilitários",
    "services": "Serviços Drizzle e server actions por domínio",
    "hooks": "Hooks React partilhados"
  },
  "aliases": {
    "@/*": "Raiz do repositório (tsconfig paths)"
  }
}
