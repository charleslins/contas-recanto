# Banco (Neon Postgres) — copie para `.env` ou `.env.local` e preencha com a sua connection string.
# Nunca commite ficheiros `.env` com credenciais reais.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Opcional (legado)
# GEMINI_API_KEY=""
# APP_URL="https://seu-dominio.vercel.app"
